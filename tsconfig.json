{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@styles/*": ["./src/styles/*"],
      "@components/*": ["./src/components/*"],
      "@layout": ["./src/layout/*"],
      "@core/*": ["./src/core/*"],
      "@utils/*": ["./src/utils/*"]
    },
  }
}